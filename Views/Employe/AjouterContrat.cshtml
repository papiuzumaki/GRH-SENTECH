@model GRH_SENTECH.ViewModels.AjouterContratViewModel

@{
    ViewData["Title"] = "Ajouter un contrat";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-file-contract"></i>
                        Nouveau contrat — @Model.EmployeNomComplet
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="AjouterContrat" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="EmployeId" />
                        <input type="hidden" asp-for="EmployeNomComplet" />
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <div class="form-group">
                            <label asp-for="TypeContrat"></label>
                            <select asp-for="TypeContrat" class="form-control"
                                    asp-items="Html.GetEnumSelectList<GRH_SENTECH.Models.Enums.TypeContrat>()">
                                <option value="">-- Choisir le type --</option>
                            </select>
                            <span asp-validation-for="TypeContrat" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label asp-for="DateDebut"></label>
                                <input asp-for="DateDebut" class="form-control" type="date" />
                                <span asp-validation-for="DateDebut" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 form-group">
                                <label asp-for="DateFin"></label>
                                <input asp-for="DateFin" class="form-control" type="date" />
                                <small class="text-muted">Laisser vide pour un CDI</small>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="SalaireBase"></label>
                            <div class="input-group">
                                <input asp-for="SalaireBase" class="form-control" type="number" min="0" step="1000" />
                                <div class="input-group-append">
                                    <span class="input-group-text">FCFA</span>
                                </div>
                            </div>
                            <span asp-validation-for="SalaireBase" class="text-danger small"></span>
                        </div>

                        <div class="form-group form-check">
                            <input asp-for="PeriodeEssai" class="form-check-input" type="checkbox" />
                            <label asp-for="PeriodeEssai" class="form-check-label">Période d'essai</label>
                        </div>

                        <div class="d-flex justify-content-between mt-3">
                            <a asp-action="Details" asp-route-id="@Model.EmployeId" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Enregistrer le contrat
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

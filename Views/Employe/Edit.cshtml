@model GRH_SENTECH.ViewModels.EmployeViewModel

@{
    ViewData["Title"] = "Modifier l'employé";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="fas fa-edit"></i> Modifier — @Model.NomComplet</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label asp-for="Matricule"></label>
                                <input asp-for="Matricule" class="form-control" readonly />
                            </div>
                            <div class="col-md-6 form-group">
                                <label asp-for="Genre"></label>
                                <select asp-for="Genre" asp-items="ViewBag.Genres" class="form-control">
                                    <option value="">-- Choisir --</option>
                                </select>
                                <span asp-validation-for="Genre" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label asp-for="Nom"></label>
                                <input asp-for="Nom" class="form-control" />
                                <span asp-validation-for="Nom" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 form-group">
                                <label asp-for="Prenom"></label>
                                <input asp-for="Prenom" class="form-control" />
                                <span asp-validation-for="Prenom" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="DateNaissance"></label>
                            <input asp-for="DateNaissance" class="form-control" type="date" />
                            <span asp-validation-for="DateNaissance" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label asp-for="DepartementId"></label>
                                <select asp-for="DepartementId" asp-items="ViewBag.Departements" class="form-control">
                                    <option value="">-- Choisir --</option>
                                </select>
                                <span asp-validation-for="DepartementId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 form-group">
                                <label asp-for="PosteId"></label>
                                <select asp-for="PosteId" asp-items="ViewBag.Postes" class="form-control">
                                    <option value="">-- Choisir --</option>
                                </select>
                                <span asp-validation-for="PosteId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-3">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Sauvegarder
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

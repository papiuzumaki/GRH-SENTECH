@{
    ViewData["Title"] = "Tableau de bord";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2><i class="fas fa-tachometer-alt"></i> Tableau de bord — GRH SENTECH</h2>
        <p class="text-muted">Vue d'ensemble des ressources humaines</p>
    </div>

    <!-- Statistiques -->
    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card border-left-primary shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="mr-3">
                        <i class="fas fa-users fa-2x text-primary"></i>
                    </div>
                    <div>
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Employés</div>
                        <div class="h3 mb-0 font-weight-bold">@ViewBag.TotalEmployes</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-left-success shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="mr-3">
                        <i class="fas fa-building fa-2x text-success"></i>
                    </div>
                    <div>
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Départements</div>
                        <div class="h3 mb-0 font-weight-bold">@ViewBag.TotalDepartements</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-left-info shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="mr-3">
                        <i class="fas fa-briefcase fa-2x text-info"></i>
                    </div>
                    <div>
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Postes</div>
                        <div class="h3 mb-0 font-weight-bold">@ViewBag.TotalPostes</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card border-left-warning shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="mr-3">
                        <i class="fas fa-umbrella-beach fa-2x text-warning"></i>
                    </div>
                    <div>
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Congés en attente</div>
                        <div class="h3 mb-0 font-weight-bold">@ViewBag.CongesEnAttente</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card border-left-danger shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="mr-3">
                        <i class="fas fa-user-times fa-2x text-danger"></i>
                    </div>
                    <div>
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Sans contrat actif</div>
                        <div class="h3 mb-0 font-weight-bold">@ViewBag.EmployesSansContrat</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Raccourcis -->
    <div class="row mt-2">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header"><strong>Accès rapide</strong></div>
                <div class="card-body">
                    <a asp-controller="Employe" asp-action="Index" class="btn btn-outline-primary mr-2 mb-2">
                        <i class="fas fa-users"></i> Liste des employés
                    </a>
                    <a asp-controller="Employe" asp-action="Create" class="btn btn-outline-success mr-2 mb-2">
                        <i class="fas fa-user-plus"></i> Ajouter un employé
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-left-primary { border-left: 4px solid #007bff !important; }
    .border-left-success { border-left: 4px solid #28a745 !important; }
    .border-left-info    { border-left: 4px solid #17a2b8 !important; }
    .border-left-warning { border-left: 4px solid #ffc107 !important; }
    .border-left-danger  { border-left: 4px solid #dc3545 !important; }
    .text-xs { font-size: 0.75rem; }
</style>

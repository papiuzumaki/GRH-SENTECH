@model GRH_SENTECH.ViewModels.CongeViewModel

@{
    ViewData["Title"] = "Demande de congé";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-umbrella-beach"></i>
                        Demande de congé — @Model.EmployeNomComplet
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Demander" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="EmployeId" />
                        <input type="hidden" asp-for="EmployeNomComplet" />
                        <div asp-validation-summary="All" class="alert alert-danger"></div>

                        <div class="form-group">
                            <label asp-for="TypeConge"></label>
                            <select asp-for="TypeConge" class="form-control"
                                    asp-items="Html.GetEnumSelectList<GRH_SENTECH.Models.Enums.TypeConge>()">
                                <option value="">-- Choisir le type --</option>
                            </select>
                            <span asp-validation-for="TypeConge" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label asp-for="DateDebut"></label>
                                <input asp-for="DateDebut" class="form-control" type="date" />
                                <span asp-validation-for="DateDebut" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 form-group">
                                <label asp-for="DateFin"></label>
                                <input asp-for="DateFin" class="form-control" type="date" />
                                <span asp-validation-for="DateFin" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Motif"></label>
                            <textarea asp-for="Motif" class="form-control" rows="3"
                                      placeholder="Précisez le motif du congé..."></textarea>
                        </div>

                        <div class="alert alert-info small">
                            <i class="fas fa-info-circle"></i>
                            Les congés annuels sont limités à <strong>30 jours</strong> par année calendaire.
                        </div>

                        <div class="d-flex justify-content-between mt-2">
                            <a asp-action="ParEmploye" asp-route-id="@Model.EmployeId" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane"></i> Envoyer la demande
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
